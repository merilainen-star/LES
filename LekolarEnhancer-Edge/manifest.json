{
  "manifest_version": 3,
  "name": "Lekolar Enhancer",
  "version": "1.24",
  "description": "Adds copy buttons, infinite scroll, and search enhancements for Lekolar sites.",
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "storage"
  ],
  "host_permissions": [
    "*://*.lekolar.fi/*",
    "*://*.lekolar.se/*",
    "*://*.lekolar.no/*",
    "*://*.lekolar.dk/*",
    "https://lekolarab.sharepoint.com/*",
    "https://api.mymemory.translated.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "omnibox": {
    "keyword": "l"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.lekolar.fi/*",
        "*://*.lekolar.se/*",
        "*://*.lekolar.no/*",
        "*://*.lekolar.dk/*"
      ],
      "js": [
        "searchUtils.js",
        "content.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ]
}
